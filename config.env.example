# Bug Bounty Harness Configuration
# 
# This file is checked into git. Edit values for your system,
# OR set environment variables (they take precedence over this file).
#
# Environment variables override config file values.
# Use : "${VAR:=default}" syntax so env vars always win.

# ============================================================================
# PATHS
# ============================================================================

# Base directory for bounty recon data (per-program folders go here)
# Override with: HARNESS_SHARED_BASE
: "${HARNESS_SHARED_BASE:=${HOME}/Shared/bounty_recon}"

# Root of the bug_bounty_harness repo
# Override with: HARNESS_ROOT
# Root of the bug_bounty_harness repo
# Auto-detected by scripts from script location - don't set here!
# Override with: HARNESS_ROOT env var
# HARNESS_ROOT=

# Wordlists directory
# Override with: HARNESS_WORDLISTS
: "${HARNESS_WORDLISTS:=${HOME}/wordlists}"

# ============================================================================
# PROVIDER SKILL PATHS
# ============================================================================

# Claude Code skills directory
# Override with: CLAUDE_SKILLS_DIR
: "${CLAUDE_SKILLS_DIR:=${HOME}/.claude/skills}"

# Codex skills directory
# Override with: CODEX_SKILLS_DIR
: "${CODEX_SKILLS_DIR:=${HOME}/.codex/skills}"

# ============================================================================
# PROVIDER CONFIG DIRECTORIES
# ============================================================================

# Claude Code config directory
: "${CLAUDE_CONFIG_DIR:=${HOME}/.claude}"

# Codex config directory
: "${CODEX_CONFIG_DIR:=${HOME}/.codex}"

# ============================================================================
# GIT
# ============================================================================

# GitHub repo URL (for cloning/pushing)
GITHUB_REPO="https://github.com/ghostonbutterbread/bug-bounty-harness.git"

# ============================================================================
# RATE LIMITING
# ============================================================================

# Default requests per second
DEFAULT_RATE_LIMIT=10

# Default concurrent threads
DEFAULT_THREADS=20
